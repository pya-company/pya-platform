{
  "name": "@undeadliner/pya-ui",
  "version": "0.0.0",
  "private": false,
  "publishConfig": { "registry": "https://npm.pkg.github.com", "access": "restricted" },
  "repository": { "type": "git", "url": "https://github.com/undeadliner/pya-platform.git" },
  "type": "module",
  "description": "Lit web components shared across Pya projects — buttons, badges, cards, filter chips, quantity steppers, plus a11y/state controllers.",
  "exports": {
    ".": "./src/index.ts",
