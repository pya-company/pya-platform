    "./controllers/*": "./src/controllers/*",
    "./helpers/*": "./src/helpers/*"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "echo '@undeadliner/pya-ui has no tests yet'"
  },
  "dependencies": {
    "@undeadliner/pya-tokens": "workspace:*",
    "lit": "^3.2.1"
  }
}
